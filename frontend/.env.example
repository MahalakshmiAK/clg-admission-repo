# frontend/.env.example
# Copy to .env.local for local dev. Vite reads this automatically.
# Variables MUST be prefixed with VITE_ to be accessible in browser code.
# Never put secrets here — these values are bundled into the JS output.

# API base URL — points at the FastAPI backend.
# In development, Vite's proxy (vite.config.ts) handles /api calls,
# so this variable is only needed for production builds.
VITE_API_BASE_URL=http://localhost:8000
